The deeper problem is that send_trigger_on_flip registers a callback but the flip that actually shows the image is inside the loop in run_image_for_duration, so the trigger and the stimulus onset are not guaranteed to be synchronized with what Unicorn Recorder sees.
The Fix
Draw the image and flip once outside the loop for the onset (this is where the trigger fires), then loop for the remaining duration:
pythondef run_image_for_duration(win, image_stim, duration, response_key=None, trigger_code=None):
    event.clearEvents(eventType="keyboard")
    clock = core.Clock()

    pressed = 0
    rt = ""

    # --- ONSET FLIP: trigger fires here, synchronized with image appearance ---
    if trigger_code is not None:
        code_bytes = str(trigger_code).encode("ascii")
        win.callOnFlip(udp_sock.sendto, code_bytes, udp_endpoint)
        win.callOnFlip(
            threading.Thread(
                target=reset_trigger_after,
                args=(TRIGGER_RESET_DELAY,),
                daemon=True
            ).start
        )

    image_stim.draw()
    win.flip()  # <-- trigger fires exactly here
    clock.reset()  # reset clock AFTER the onset flip for accurate RT

    # --- HOLD LOOP: keep image on screen, collect responses ---
    while clock.getTime() < duration:
        image_stim.draw()
        win.flip()

        if response_key is not None:
            keys = event.getKeys(keyList=[response_key] + QUIT_KEYS, timeStamped=clock)
            if keys:
                for key, key_rt in keys:
                    if key in QUIT_KEYS:
                        cleanup_and_quit(win)
                    if key == response_key and pressed == 0:
                        pressed = 1
                        rt = key_rt

    return pressed, rt
